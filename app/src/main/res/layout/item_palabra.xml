<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!-- IMAGEN -->
        <ImageView
            android:id="@+id/imgPalabra"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:scaleType="centerCrop"
            android:layout_marginEnd="12dp"
            android:src="@drawable/ic_launcher_background"
            android:contentDescription="Imagen de la palabra" />

        <!-- TEXTOS - Ocupa todo el espacio disponible -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtNahuat"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/montserrat_bold"
                android:text="Tlaolli"
                android:textColor="@color/main_text"
                android:textSize="18sp"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/txtEspanol"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="@font/montserrat_regular"
                android:text="Maíz"
                android:textColor="@color/text_secundario"
                android:textSize="14sp"
                android:maxLines="1"
                android:ellipsize="end" />

        </LinearLayout>

        <!-- BOTONES - Pegados a la derecha y más juntos -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginStart="8dp">

            <!-- AUDIO - MaterialButton con área táctil de 48dp pero visual de 40dp -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAudio"
                style="@style/Widget.Material3.Button.IconButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:padding="4dp"
                android:backgroundTint="@color/boton"
                android:insetLeft="0dp"
                android:insetTop="0dp"
                android:insetRight="0dp"
                android:insetBottom="0dp"
                android:contentDescription="Reproducir audio"
                app:icon="@android:drawable/ic_media_play"
                app:iconGravity="textStart"
                app:iconSize="24dp"
                app:iconTint="@color/white"
                app:cornerRadius="24dp" />

            <!-- FAVORITO - ImageButton con área táctil de 40dp pero visual de 32dp -->
            <ImageButton
                android:id="@+id/btnFavorito"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:padding="4dp"
                android:layout_marginStart="4dp"
                android:background="@android:color/transparent"
                android:src="@drawable/ic_favorite_border"
                android:visibility="gone"
                android:contentDescription="Agregar a favoritos"
                app:tint="@color/text_secundario" />

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>