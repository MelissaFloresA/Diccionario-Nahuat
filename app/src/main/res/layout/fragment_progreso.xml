<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_2">

    <!-- Header -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/header_busqueda"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="#F0F9FF"
        android:paddingHorizontal="16dp"
        android:paddingTop="40dp"
        android:paddingBottom="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Botón back -->
        <ImageButton
            android:id="@+id/boton_retroceder"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@android:color/transparent"
            android:src="?android:attr/homeAsUpIndicator"
            android:contentDescription="Retroceder"
            app:tint="@color/main_text"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

        <!-- TÍTULO CENTRADO REAL -->
        <TextView
            android:id="@+id/texto_titulo_progreso"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Aprendizaje"
            android:textSize="20sp"
            android:textColor="@color/main_text"
            android:fontFamily="@font/montserrat_bold"
            android:gravity="center"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>

        <!-- SUBTÍTULO CENTRADO -->
        <TextView
            android:id="@+id/texto_subtitulo_progreso"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="¡Pon a prueba tu aprendizaje!"
            android:textSize="12sp"
            android:textColor="@color/text_secundario"
            android:fontFamily="@font/montserrat_regular"
            android:gravity="center"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/texto_titulo_progreso"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Línea -->
    <View
        android:id="@+id/linea_divisoria"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="@color/text_secundario"
        android:alpha="0.3"
        app:layout_constraintTop_toBottomOf="@id/header_busqueda"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Contenido -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:padding="24dp"
        app:layout_constraintTop_toBottomOf="@id/linea_divisoria"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <!-- Palabra -->
            <TextView
                android:id="@+id/textoPalabra"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cargando..."
                android:textSize="38sp"
                android:textColor="@color/main_text"
                android:fontFamily="@font/montserrat_semibold"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="48dp"/>

            <!-- Opciones -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:rowCount="2"
                android:useDefaultMargins="true">

                <!-- Opción 1 -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/opcion1"
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_columnWeight="1"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardCornerRadius="16dp"
                    app:cardBackgroundColor="@color/white"
                    app:contentPadding="18dp">

                    <TextView
                        android:id="@+id/txtOpcion1"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:textSize="18sp"
                        android:textColor="@color/black"
                        android:fontFamily="@font/montserrat_regular"/>
                </androidx.cardview.widget.CardView>

                <!-- Opción 2 -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/opcion2"
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_columnWeight="1"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardCornerRadius="16dp"
                    app:cardBackgroundColor="@color/white"
                    app:contentPadding="18dp">

                    <TextView
                        android:id="@+id/txtOpcion2"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:textSize="18sp"
                        android:textColor="@color/black"
                        android:fontFamily="@font/montserrat_regular"/>
                </androidx.cardview.widget.CardView>

                <!-- Opción 3 -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/opcion3"
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_columnWeight="1"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardCornerRadius="16dp"
                    app:cardBackgroundColor="@color/white"
                    app:contentPadding="18dp">

                    <TextView
                        android:id="@+id/txtOpcion3"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:textSize="18sp"
                        android:textColor="@color/black"
                        android:fontFamily="@font/montserrat_regular"/>
                </androidx.cardview.widget.CardView>

                <!-- Opción 4 -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/opcion4"
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_columnWeight="1"
                    android:clickable="true"
                    android:focusable="true"
                    app:cardCornerRadius="16dp"
                    app:cardBackgroundColor="@color/white"
                    app:contentPadding="18dp">

                    <TextView
                        android:id="@+id/txtOpcion4"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:textSize="18sp"
                        android:textColor="@color/black"
                        android:fontFamily="@font/montserrat_regular"/>
                </androidx.cardview.widget.CardView>

            </GridLayout>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>