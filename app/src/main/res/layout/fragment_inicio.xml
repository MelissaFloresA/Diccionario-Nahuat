<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_1"
    android:paddingBottom="0dp"
    android:scrollbars="none"
    tools:context=".ui.InicioFragment">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Header - Título de la aplicación -->
        <LinearLayout
            android:id="@+id/header_titulo_app"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="40dp"
            android:layout_marginBottom="0dp"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/texto_titulo_principal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/montserrat_semibold"
                android:text="Diccionario"
                android:textColor="@color/black"
                android:textSize="32sp"
                tools:ignore="HardcodedText"/>

            <TextView
                android:id="@+id/texto_subtitulo_nahuat"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/montserrat_semibold"
                android:text="Náhuat"
                android:textColor="@color/boton"
                android:textSize="28sp"
                tools:ignore="HardcodedText"/>

        </LinearLayout>

        <!-- Card de la Palabra del Día -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card_palabra_dia"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="20dp"
            app:cardBackgroundColor="@color/boton"
            app:cardCornerRadius="20dp"
            app:cardElevation="4dp"
            app:cardUseCompatPadding="true"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/header_titulo_app">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="24dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/texto_etiqueta_palabra_dia"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/montserrat_medium"
                        android:text="Palabra del día"
                        android:textAllCaps="true"
                        android:textColor="@color/text_card_dia"
                        android:textSize="12sp"
                        tools:ignore="TextContrastCheck,HardcodedText"/>

                    <TextView
                        android:id="@+id/texto_palabra_nahuat"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:fontFamily="@font/montserrat_bold"
                        android:text="Siwat"
                        android:textColor="@color/white"
                        android:textSize="28sp"
                        tools:ignore="HardcodedText"/>

                    <TextView
                        android:id="@+id/texto_significado_palabra"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/montserrat_regular"
                        android:text="Mujer"
                        android:textColor="@color/white"
                        android:textSize="20sp"
                        tools:ignore="HardcodedText"/>

                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/boton_audio_palabra"
                    style="@style/Widget.Material3.Button.IconButton"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:layout_gravity="center_vertical"
                    android:backgroundTint="@color/white"
                    android:insetLeft="0dp"
                    android:insetTop="0dp"
                    android:insetRight="0dp"
                    android:insetBottom="0dp"
                    app:icon="@drawable/ic_volume_up"
                    app:iconGravity="textStart"
                    app:iconSize="24dp"
                    app:iconTint="@color/boton"
                    android:contentDescription="Reproducir audio"
                    tools:ignore="HardcodedText,TextContrastCheck"/>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Título de Sección Categorías (sin botón Ver todo) -->
        <TextView
            android:id="@+id/texto_titulo_categorias"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="32dp"
            android:fontFamily="@font/montserrat_bold"
            android:text="Categorías"
            android:textColor="@color/main_text"
            android:textSize="20sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/card_palabra_dia"
            tools:ignore="HardcodedText"/>

        <!-- Grid de Categorías -->
        <androidx.gridlayout.widget.GridLayout
            android:id="@+id/grid_categorias"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="8dp"
            app:columnCount="2"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/texto_titulo_categorias">

            <!-- Tarjeta Categoría: Familia -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_categoria_familia"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                app:layout_columnWeight="1"
                app:cardBackgroundColor="@color/cards"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardPreventCornerOverlap="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <ImageView
                        android:id="@+id/imagen_icono_familia"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginBottom="8dp"
                        android:src="@drawable/ic_familia"
                        app:tint="@color/boton"
                        tools:ignore="ContentDescription"/>

                    <TextView
                        android:id="@+id/texto_nombre_categoria_familia"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/montserrat_semibold"
                        android:gravity="center_horizontal"
                        android:text="Familia"
                        android:textColor="@color/main_text"
                        android:textSize="16sp"
                        tools:ignore="HardcodedText"/>

                    <TextView
                        android:id="@+id/texto_conteo_categoria_familia"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:fontFamily="@font/montserrat_regular"
                        android:gravity="center_horizontal"
                        android:text=""
                        android:textColor="@color/text_secundario"
                        android:textSize="12sp" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Tarjeta Categoría: Vestimenta -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_categoria_vestimenta"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                app:layout_columnWeight="1"
                app:cardBackgroundColor="@color/cards"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardPreventCornerOverlap="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <ImageView
                        android:id="@+id/imagen_icono_vestimenta"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginBottom="8dp"
                        android:src="@drawable/ic_vestimenta"
                        app:tint="@color/boton"
                        tools:ignore="ContentDescription"/>

                    <TextView
                        android:id="@+id/texto_nombre_categoria_vestimenta"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/montserrat_semibold"
                        android:gravity="center_horizontal"
                        android:text="Vestimenta"
                        android:textColor="@color/main_text"
                        android:textSize="16sp"
                        tools:ignore="HardcodedText"/>

                    <TextView
                        android:id="@+id/texto_conteo_categoria_vestimenta"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:fontFamily="@font/montserrat_regular"
                        android:gravity="center_horizontal"
                        android:text=""
                        android:textColor="@color/text_secundario"
                        android:textSize="12sp" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Tarjeta Categoría: Escuela -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_categoria_escuela"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                app:layout_columnWeight="1"
                app:cardBackgroundColor="@color/cards"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardPreventCornerOverlap="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <ImageView
                        android:id="@+id/imagen_icono_escuela"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginBottom="8dp"
                        android:src="@drawable/ic_escuela"
                        app:tint="@color/boton"
                        tools:ignore="ContentDescription"/>

                    <TextView
                        android:id="@+id/texto_nombre_categoria_escuela"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/montserrat_semibold"
                        android:gravity="center_horizontal"
                        android:text="Escuela"
                        android:textColor="@color/main_text"
                        android:textSize="16sp"
                        tools:ignore="HardcodedText"/>

                    <TextView
                        android:id="@+id/texto_conteo_categoria_escuela"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:fontFamily="@font/montserrat_regular"
                        android:gravity="center_horizontal"
                        android:text=""
                        android:textColor="@color/text_secundario"
                        android:textSize="12sp" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Tarjeta Categoría: Personas -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_categoria_personas"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                app:layout_columnWeight="1"
                app:cardBackgroundColor="@color/cards"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardPreventCornerOverlap="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <ImageView
                        android:id="@+id/imagen_icono_personas"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginBottom="8dp"
                        android:src="@drawable/ic_personas"
                        app:tint="@color/boton"
                        tools:ignore="ContentDescription"/>

                    <TextView
                        android:id="@+id/texto_nombre_categoria_personas"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/montserrat_semibold"
                        android:gravity="center_horizontal"
                        android:text="Personas"
                        android:textColor="@color/main_text"
                        android:textSize="16sp"
                        tools:ignore="HardcodedText"/>

                    <TextView
                        android:id="@+id/texto_conteo_categoria_personas"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:fontFamily="@font/montserrat_regular"
                        android:gravity="center_horizontal"
                        android:text=""
                        android:textColor="@color/text_secundario"
                        android:textSize="12sp" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Tarjeta Categoría: Alimentos -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_categoria_alimentos"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                app:layout_columnWeight="1"
                app:cardBackgroundColor="@color/cards"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardPreventCornerOverlap="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <ImageView
                        android:id="@+id/imagen_icono_alimentos"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginBottom="8dp"
                        android:src="@drawable/ic_alimentos"
                        app:tint="@color/boton"
                        tools:ignore="ContentDescription"/>

                    <TextView
                        android:id="@+id/texto_nombre_categoria_alimentos"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/montserrat_semibold"
                        android:gravity="center_horizontal"
                        android:text="Alimentos"
                        android:textColor="@color/main_text"
                        android:textSize="16sp"
                        tools:ignore="HardcodedText"/>

                    <TextView
                        android:id="@+id/texto_conteo_categoria_alimentos"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:fontFamily="@font/montserrat_regular"
                        android:gravity="center_horizontal"
                        android:text=""
                        android:textColor="@color/text_secundario"
                        android:textSize="12sp" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Tarjeta Categoría: Animales -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_categoria_animales"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                app:layout_columnWeight="1"
                app:cardBackgroundColor="@color/cards"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardPreventCornerOverlap="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <ImageView
                        android:id="@+id/imagen_icono_animales"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginBottom="8dp"
                        android:src="@drawable/ic_animales"
                        app:tint="@color/boton"
                        tools:ignore="ContentDescription"/>

                    <TextView
                        android:id="@+id/texto_nombre_categoria_animales"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/montserrat_semibold"
                        android:gravity="center_horizontal"
                        android:text="Animales"
                        android:textColor="@color/main_text"
                        android:textSize="16sp"
                        tools:ignore="HardcodedText"/>

                    <TextView
                        android:id="@+id/texto_conteo_categoria_animales"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:fontFamily="@font/montserrat_regular"
                        android:gravity="center_horizontal"
                        android:text=""
                        android:textColor="@color/text_secundario"
                        android:textSize="12sp" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </androidx.gridlayout.widget.GridLayout>

        <!-- Sin espacio adicional al final -->
    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>